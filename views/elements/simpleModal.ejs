<dialog id="editModal">
  <h2 id="modalTitle"></h2>
  <form method="post" id="editForm" action="/categories">
    <div>
      <label for="nameInput">Name</label>
      <input type="text" name="name" id="nameInput" />
    </div>
    <p id="errorP"></p>
    <div class="btnGroup">
      <button type="submit">Save</button>
      <button type="button" onclick="closeModal()" class="deleteBtn">
        Cancel
      </button>
    </div>
  </form>
</dialog>
